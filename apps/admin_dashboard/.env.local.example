# Kaw Kaw Admin Dashboard — environment
# Copy to .env.local for local dev. In Vercel, set these as Project env vars.

# Backend API (include the /api/v1 prefix)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1

# Firebase Web app config (project kawkaw08). Get these from a WEB app in the
# Firebase console (or scripts/firebase-web-config.js). The Web API key differs
# from the Android one and is safe to expose (it's a public client identifier).
NEXT_PUBLIC_FIREBASE_API_KEY=REPLACE_ME
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=kawkaw08.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=kawkaw08
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=kawkaw08.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=REPLACE_ME
NEXT_PUBLIC_FIREBASE_APP_ID=REPLACE_ME

# Dev-only: set to "true" to disable Firebase app verification (reCAPTCHA) so a
# configured test phone number logs in without a real SMS. NEVER true in prod.
NEXT_PUBLIC_FIREBASE_TEST_MODE=false

# Optional error monitoring (Sentry). Leave blank to disable.
NEXT_PUBLIC_SENTRY_DSN=
