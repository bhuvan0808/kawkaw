# =====================================================================
# Kaw Kaw API — environment template
# Copy to `.env` and fill in. NEVER commit the real `.env`.
# Validated on boot (see src/common/config/env.validation.ts) — the
# process refuses to start if anything required is missing or malformed.
# =====================================================================

# --- Runtime ---------------------------------------------------------
NODE_ENV=development            # development | test | production
PORT=3000
API_GLOBAL_PREFIX=api
LOG_LEVEL=info                  # fatal|error|warn|info|debug|trace

# --- Database (PostgreSQL — Avion) -----------------------------------
# postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL=postgresql://kawkaw:kawkaw@localhost:5432/kawkaw?schema=public

# --- Redis (Upstash) -------------------------------------------------
# rediss://default:PASSWORD@HOST:PORT   (use rediss:// for TLS / Upstash)
REDIS_URL=redis://localhost:6379

# --- JWT -------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# --- Firebase (project kawkaw08) -------------------------------------
FIREBASE_PROJECT_ID=kawkaw08
FIREBASE_CLIENT_EMAIL=
# Paste the full private key on ONE line with literal \n for newlines, wrapped in quotes:
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# --- Public URLs / CORS ----------------------------------------------
API_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
# Comma-separated allow-list for CORS (admin dashboard + app webviews).
CORS_ORIGINS=http://localhost:3001,https://admin.kawkaw.in

# --- Rate limiting ---------------------------------------------------
THROTTLE_TTL=60                 # seconds
THROTTLE_LIMIT=120              # requests per TTL per client
AUTH_THROTTLE_LIMIT=10          # stricter limit for auth endpoints

# --- OTP / sessions (Redis-backed) -----------------------------------
OTP_MAX_ATTEMPTS=5
OTP_WINDOW_SECONDS=600

# --- Uploads (prescriptions) -----------------------------------------
UPLOAD_MAX_BYTES=5242880        # 5 MB
UPLOAD_ALLOWED_MIME=image/jpeg,image/png,image/webp

# --- Maps (OpenStreetMap stack) --------------------------------------
NOMINATIM_URL=https://nominatim.openstreetmap.org
OSRM_URL=https://router.project-osrm.org

# --- Business defaults (seeded into Settings on first run) -----------
DEFAULT_DELIVERY_FEE=20
LAUNCH_CITY=Bhadrachalam

# --- Monitoring (optional) -------------------------------------------
# Sentry error monitoring. Leave blank to disable. Set in Render for prod.
SENTRY_DSN=
